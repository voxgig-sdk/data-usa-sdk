  entity: health: {
    path: "/_health": {
      op: load: method: *GET
    }
  }

  entity: member: {
    path: "/tesseract/members": {
      op: list: method: *GET
    }
  }

  entity: module_status: {
    path: "/calcs/": {
      op: load: method: *GET
    }
