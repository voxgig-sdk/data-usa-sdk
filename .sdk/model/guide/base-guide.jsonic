      op: load: method: *GET
    }
  }

  entity: tesseract_cube: {
    path: "/complexity/cubes/{cube_name}": {
      rename: param: "cube_name": *"id"
      op: load: method: *GET
    }
    path: "/tesseract/cubes/{cube_name}": {
      rename: param: "cube_name": *"id"
      op: load: method: *GET
